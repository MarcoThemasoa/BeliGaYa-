# GEMINI_API_KEY: Required for Gemini AI API calls on the backend.
# Get this from: https://ai.google.dev
GEMINI_API_KEY="your_gemini_api_key_here"

# HF_TOKEN: Required for Hugging Face sentiment analysis.
# Get this from: https://huggingface.co/settings/tokens
HF_TOKEN="your_huggingface_token_here"

# NODE_ENV: Set to 'production' for Vercel deployment
NODE_ENV="development"

